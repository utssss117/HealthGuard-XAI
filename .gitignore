# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
env/
venv/

# Environment variables — NEVER commit these files
.env
.env.local
.env.*.local

# Model outputs — allow models dir, ignore plots/metrics
outputs/plots/
outputs/metrics/
# Allow trained model files needed for Vercel serverless deployment
!outputs/models/
!outputs/models/*.pkl

# Data files
data/

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/

# Clerk configuration (can include secrets)
/.clerk/

# Node/Next.js
node_modules/
.next/

# Databases
*.db
*.sqlite

# Debug scripts
tmp_*.py
debug_*.py
